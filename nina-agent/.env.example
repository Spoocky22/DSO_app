# URL de ton app Vercel, sans slash final
DSO_APP_URL=https://ton-app.vercel.app

# Même valeur que NINA_INGEST_TOKEN dans Vercel
NINA_INGEST_TOKEN=change-me-long-random-token

# WebSocket du plugin NINA Advanced API
NINA_WS_URL=ws://localhost:1888/v2/socket

# ntfy optionnel. Laisse vide pour désactiver.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
NTFY_TOKEN=

# Optionnel : utilisé seulement si NINA renvoie un filtre vide.
# À utiliser avec prudence : mets par exemple H-alpha seulement si toute la session
# sans nom de filtre est vraiment en H-alpha.
NINA_FALLBACK_FILTER=L
