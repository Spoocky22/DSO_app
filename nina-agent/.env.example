# URL de ton app Vercel, sans slash final
DSO_APP_URL=https://ton-app.vercel.app

# Même valeur que NINA_INGEST_TOKEN dans Vercel
NINA_INGEST_TOKEN=change-me-long-random-token

# WebSocket du plugin NINA Advanced API
NINA_WS_URL=ws://localhost:1888/v2/socket

# Si NINA renvoie un filtre vide ou "?", on le range en L.
# Mets "off" pour désactiver ce fallback.
NINA_FALLBACK_FILTER=L

# ntfy optionnel. Laisse NTFY_TOPIC vide pour désactiver toutes les notifications.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
NTFY_TOKEN=

# Notifications ntfy.
# Par défaut : pas de notif à chaque image, mais résumé de fin de nuit après inactivité.
NTFY_NOTIFY_EACH_IMAGE=false
NTFY_NOTIFY_CONNECTION=false
NTFY_NOTIFY_ERRORS=true
NTFY_END_OF_NIGHT_SUMMARY=true

# Déclenchement du résumé de fin de nuit : si aucune image NINA n'arrive pendant X minutes.
# 45 min est un bon compromis. Mets 90 si vous avez souvent de longues pauses entre cibles.
NTFY_NIGHT_IDLE_MINUTES=45

# Discord optionnel. Crée un webhook dans le salon Discord voulu puis colle l'URL ici.
# Laisse vide pour désactiver Discord.
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=DSO Sync
